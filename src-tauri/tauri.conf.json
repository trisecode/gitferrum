{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitFerrum",
  "version": "0.6.0",
  "identifier": "com.trisecode.gitferrum",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "GitFerrum",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": "v1Compatible",
    "macOS": {
      "entitlements": "Entitlements.plist",
      "signingIdentity": "Developer ID Application: TRISECODE LLC (72QUJ9J38X)"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/trisecode/gitferrum/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzQ0UxMEJFNzYyRkNBNTcKUldSWHlpOTJ2aERPVXcvc2YwbGNRcThUYzhHV0J0TnN4V05XVjhTR3VGZUIrNm1NVmw3aUxHVUQK"
    }
  }
}
